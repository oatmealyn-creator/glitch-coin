---
const year = new Date().getFullYear();
---

<footer class="w-full px-6 py-10 border-t border-outline-variant/30">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
    <div class="font-headline text-xl font-extrabold tracking-tighter text-primary">
      GLITCH
    </div>

    <div class="flex items-center gap-4">
      <a href="https://x.com/glitchcoin" target="_blank" rel="noopener noreferrer" class="clay-card w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:text-primary transition-all" aria-label="X / Twitter">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16z"/><path d="M4 20l6.768 -6.768m2.46 -2.46L20 4"/></svg>
      </a>
      <a href="https://t.me/glitchcoin" target="_blank" rel="noopener noreferrer" class="clay-card w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:text-primary transition-all" aria-label="Telegram">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10l-4 4l6 6l4 -16l-18 7l4 2l2 6l3 -4"/></svg>
      </a>
      <a href="https://dexscreener.com/" target="_blank" rel="noopener noreferrer" class="clay-card w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:text-primary transition-all" aria-label="DexScreener">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 16l4 -8l4 4l4 -6"/></svg>
      </a>
    </div>

    <p class="font-label text-xs tracking-widest font-semibold uppercase text-on-surface-variant">
      &copy; {year} Digital Plasticity
    </p>
  </div>
</footer>
