---
const year = new Date().getFullYear();
---

<footer class="w-full px-6 py-10 border-t border-outline-variant/30">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
    <div class="font-headline text-xl font-extrabold tracking-tighter text-primary">
      GLITCH
    </div>

    <div class="flex items-center gap-4">
      <a href="#" class="clay-card w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:text-primary transition-all font-headline text-sm font-bold" aria-label="X / Twitter">X</a>
      <a href="#" class="clay-card w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:text-primary transition-all font-headline text-sm font-bold" aria-label="Telegram">T</a>
      <a href="#" class="clay-card w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:text-primary transition-all font-headline text-sm font-bold" aria-label="DexScreener">D</a>
    </div>

    <p class="font-label text-xs tracking-widest font-semibold uppercase text-on-surface-variant">
      &copy; {year} Digital Plasticity
    </p>
  </div>
</footer>
