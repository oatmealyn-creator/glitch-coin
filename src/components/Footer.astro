---
const year = new Date().getFullYear();
---

<footer class="w-full mt-[32px] px-[24px] py-[32px] flex flex-col md:flex-row justify-between items-center gap-[16px] bg-surface-container rounded-t-lg shadow-[0_-10px_40px_rgba(0,0,0,0.05)] z-20 relative">
  <div class="font-headline text-[24px] leading-[1.3] font-black text-primary">
    GLITCH
  </div>

  <div class="flex flex-wrap justify-center gap-6 font-label text-[12px] leading-[1] tracking-[0.05em] font-semibold uppercase">
    <a class="text-on-surface-variant hover:text-tertiary transition-colors duration-200" href="#">X / Twitter</a>
    <a class="text-on-surface-variant hover:text-tertiary transition-colors duration-200" href="#">Telegram</a>
    <a class="text-on-surface-variant hover:text-tertiary transition-colors duration-200" href="#">DexScreener</a>
    <a class="text-on-surface-variant hover:text-tertiary transition-colors duration-200" href="#">Whitepaper</a>
  </div>

  <div class="text-on-surface-variant font-label text-[12px] leading-[1] tracking-[0.05em] font-semibold text-center md:text-right">
    &copy; {year} GLITCH Ecosystem. Built with Digital Plasticity.
  </div>
</footer>
